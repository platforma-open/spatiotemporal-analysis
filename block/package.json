{
  "name": "@platforma-open/milaboratories.spatiotemporal-analysis",
  "version": "1.0.3",
  "scripts": {
    "build": "shx rm -rf ./block-pack && block-tools pack",
    "mark-stable": "block-tools mark-stable -r 's3://milab-euce1-prod-pkgs-s3-block-registry/pub/releases/?region=eu-central-1'",
    "prepublishOnly": "block-tools pack && block-tools publish -r 's3://milab-euce1-prod-pkgs-s3-block-registry/pub/releases/?region=eu-central-1'",
    "do-pack": "shx rm -f *.tgz && block-tools pack && pnpm pack && shx mv *.tgz package.tgz"
  },
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "dependencies": {
    "@platforma-open/milaboratories.spatiotemporal-analysis.workflow": "workspace:*",
    "@platforma-open/milaboratories.spatiotemporal-analysis.model": "workspace:*",
    "@platforma-open/milaboratories.spatiotemporal-analysis.ui": "workspace:*"
  },
  "block": {
    "components": {
      "workflow": "@platforma-open/milaboratories.spatiotemporal-analysis.workflow/dist/tengo/tpl/main.plj.gz",
      "model": "@platforma-open/milaboratories.spatiotemporal-analysis.model/dist/model.json",
      "ui": "@platforma-open/milaboratories.spatiotemporal-analysis.ui/dist"
    },
    "meta": {
      "title": "Spatiotemporal Analysis",
      "url": "https://github.com/platforma-open/spatiotemporal-analysis",
      "support": "mailto:support@milaboratories.com",
      "description": "Profiles clonal abundance across tissue compartments, timepoints, and subjects — computing restriction, temporal expansion, and cross-subject convergence metrics.",
      "longDescription": "file:../docs/description.md",
      "changelog": "file:../CHANGELOG.md",
      "tags": [
        "AIRR",
        "downstream",
        "VDJ"
      ],
      "organization": {
        "name": "MiLaboratories Inc",
        "url": "https://milaboratories.com/"
      },
      "supportedPlatforms": [
        "linux-x64",
        "linux-aarch64",
        "macosx-x64",
        "macosx-aarch64"
      ]
    }
  },
  "devDependencies": {
    "@platforma-sdk/block-tools": "catalog:"
  },
  "packageManager": "pnpm@9.12.0"
}
